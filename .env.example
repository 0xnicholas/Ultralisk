# 推理后端: mock | vllm | tgi | sglang
INFERENCE_BACKEND=mock
INFERENCE_BASE_URL=http://localhost:8000
INFERENCE_API_KEY=
INFERENCE_TIMEOUT=60
MODEL_NAME=mock-model-0.1

# 配额存储: memory | redis | redis_pg
QUOTA_STORE=memory
REDIS_URL=redis://localhost:6379/0
PG_DSN=postgresql://ultralisk:ultralisk@localhost:5432/ultralisk
DEFAULT_DAILY_TOKEN_QUOTA=100000
DEFAULT_MONTHLY_TOKEN_QUOTA=2000000

# 内容安全
SAFETY_ENABLED=1
MAX_INPUT_CHARS=8000

# 审核模型(OpenAI 兼容端点,仅非流式路径生效)
SAFETY_MODEL_ENABLED=0
SAFETY_MODEL_BASE_URL=http://localhost:8002
SAFETY_MODEL_NAME=meta-llama/Llama-Guard-3-8B
SAFETY_MODEL_API_KEY=
SAFETY_MODEL_TIMEOUT=10
# 1=fail-open(审核宕机放行,可用性优先) 0=fail-closed(拦截,安全优先)
SAFETY_MODEL_FAIL_OPEN=1

# 日志
LOG_LEVEL=INFO

# 追踪(OpenTelemetry;默认关)
TRACING_ENABLED=0
OTEL_SERVICE_NAME=ultralisk
OTEL_EXPORTER=console
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
