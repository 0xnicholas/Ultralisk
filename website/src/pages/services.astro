---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import { ArrowRight } from 'lucide-astro';
---

<Layout
  title="服务支持 — Ultralisk"
  description="部署实施、托管运维、技术支持，帮助企业快速落地并持续运营 AI 数据中心。"
>
  <Header />
  <main id="main-content" class="flex-1">
    <!-- Hero -->
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-7xl px-6 py-20 sm:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
            专业服务，陪你跑通 AI 数据中心
          </h1>
          <p class="mt-6 text-lg text-slate-600">
            从方案设计到长期运维，Ultralisk 团队提供端到端交付支持。
          </p>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid gap-8 md:grid-cols-3">
        <ServiceCard
          title="部署实施服务"
          description="从需求调研到集群上线，提供一站式交付，确保平台与你的环境无缝衔接。"
          items={['需求调研与现状评估', '架构设计与方案输出', '集群交付与平台接入', '模型对接与初始验证']}
        />
        <ServiceCard
          title="托管运维服务"
          description="7×24 监控与响应，让你的团队专注于模型与业务，而非基础设施。"
          items={['7×24 监控与告警响应', '容量规划与弹性建议', '版本升级与补丁管理', '备份恢复与容灾演练']}
        />
        <ServiceCard
          title="技术支持服务"
          description="提供 SLA 保障与专家咨询，快速响应问题并赋能内部团队。"
          items={['SLA 保障与工单响应', '专家咨询与架构评审', '故障排查与根因分析', '培训赋能与知识转移']}
        />
      </div>
    </section>

    <!-- Process timeline -->
    <section class="bg-slate-50 py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">服务流程</h2>
          <p class="mt-4 text-slate-600">从评估到持续运维，每一步都有清晰交付物。</p>
        </div>
        <ProcessTimeline
          steps={[
            { title: '评估', description: '了解现状、需求与约束，识别关键风险。' },
            { title: '设计', description: '输出架构与交付方案，明确里程碑。' },
            { title: '部署', description: '平台与集群落地，完成接入与验证。' },
            { title: '运维', description: '持续监控、优化与版本演进。' },
          ]}
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-brand-900 py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          需要部署实施或长期运维支持？
        </h2>
        <p class="mt-4 text-brand-100">告诉我们你的时间表和目标，我们制定服务方案。</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-base font-semibold text-brand-700 transition-colors hover:bg-brand-50"
          >
            联系服务团队
            <ArrowRight class="h-4 w-4" />
          </a>
          <a
            href="/solutions"
            class="rounded-xl border border-brand-400 bg-transparent px-6 py-3 text-base font-medium text-white transition-colors hover:bg-brand-800"
          >
            查看解决方案
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
