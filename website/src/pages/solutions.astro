---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SolutionCard from '../components/SolutionCard.astro';
import { ArrowRight } from 'lucide-astro';
---

<Layout
  title="解决方案 — Ultralisk"
  description="面向已有数据中心、新建私有 AI 中心、企业多租户场景的统一管控解决方案。"
>
  <Header />
  <main id="main-content" class="flex-1">
    <!-- Hero -->
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-7xl px-6 py-20 sm:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
            面向企业的 AI 数据中心解决方案
          </h1>
          <p class="mt-6 text-lg text-slate-600">
            无论是已有基础设施还是新建集群，Ultralisk 都能帮助企业统一管控、快速交付、安全运营。
          </p>
        </div>
      </div>
    </section>

    <!-- Solutions -->
    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid gap-8 lg:grid-cols-3">
        <SolutionCard
          title="已有数据中心，缺统一管控"
          pain="多集群、多工具并行，信息孤岛严重，排障困难，资源利用率难以看清。"
          solution="接入 Ultralisk 控制台，统一纳管现有 K8s/Slurm/GPU 资源，建立统一可观测与告警体系。"
          benefit="降低运维复杂度，提升资源利用率，缩短故障定位时间。"
        />
        <SolutionCard
          title="新建私有 AI 数据中心"
          pain="从零搭建技术复杂，交付周期长，团队经验不足，难以快速支撑业务上线。"
          solution="采用 Ultralisk 标准化交付方案，平台预装、集群自动初始化，并配备专业服务团队支持。"
          benefit="数周内部署上线，而不是数月，降低试错成本。"
        />
        <SolutionCard
          title="企业多租户 AI 平台"
          pain="部门/项目共用 GPU，资源争抢、成本难摊、权限难管，合规审计压力大。"
          solution="通过 Ultralisk 配额管理、租户隔离、审计日志与成本分摊，实现安全共享。"
          benefit="安全共享，成本透明，合规就绪。"
        />
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-slate-50 py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          找到适合你企业的方案？
        </h2>
        <p class="mt-4 text-slate-600">联系我们，获取针对你的场景评估与建议。</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-700"
          >
            预约咨询
            <ArrowRight class="h-4 w-4" />
          </a>
          <a
            href="/platform"
            class="rounded-xl border border-slate-200 bg-white px-6 py-3 text-base font-medium text-slate-700 transition-colors hover:border-slate-300 hover:text-slate-900"
          >
            了解平台能力
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
