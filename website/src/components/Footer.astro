---
const GITHUB_URL = 'https://github.com/PLACEHOLDER/Ultralisk';
const DOCS_URL = 'https://docs.ultralisk.dev';
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2 text-lg font-semibold text-slate-900">
          <img src="/logo.svg" alt="" class="h-6 w-6" />
          <span>Ultralisk</span>
        </a>
        <p class="mt-3 text-sm text-slate-600">
          面向自建 AI 数据中心的统一管控平台，私有化部署、统一控制台、快速交付、专业服务。
        </p>
        <p class="mt-4 text-sm text-slate-500">© 2026 Ultralisk. MIT License.</p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900">产品</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/platform" class="text-sm text-slate-600 transition-colors hover:text-brand-600">平台能力</a>
          </li>
          <li>
            <a href="/solutions" class="text-sm text-slate-600 transition-colors hover:text-brand-600">解决方案</a>
          </li>
          <li>
            <a href="/services" class="text-sm text-slate-600 transition-colors hover:text-brand-600">服务支持</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900">资源</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href={DOCS_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-600 transition-colors hover:text-brand-600"
            >
              文档
            </a>
          </li>
          <li>
            <a
              href={GITHUB_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-600 transition-colors hover:text-brand-600"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900">法律</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/privacy" class="text-sm text-slate-600 transition-colors hover:text-brand-600">隐私政策</a>
          </li>
          <li>
            <a href="/terms" class="text-sm text-slate-600 transition-colors hover:text-brand-600">服务条款</a>
          </li>
          <li>
            <a
              href={`${GITHUB_URL}/blob/main/LICENSE`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-600 transition-colors hover:text-brand-600"
            >
              License (MIT)
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
