---
export interface Props {
  variant: 'home' | 'platform';
}

const { variant } = Astro.props;
const isHome = variant === 'home';
const width = isHome ? 720 : 800;
const height = isHome ? 320 : 400;
---

<svg
  role="img"
  aria-labelledby="arch-title arch-desc"
  class="h-auto w-full"
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
>
  <title id="arch-title">Ultralisk 分层架构图</title>
  <desc id="arch-desc">
    从裸金属 GPU、集群编排、平台服务到推理 API 的四层架构，展示 Ultralisk Core 所处的推理接入层位置。
  </desc>

  <defs>
    <pattern id="dots" x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
      <circle cx="2" cy="2" r="1.5" class="fill-slate-100" />
    </pattern>
  </defs>

  <rect width={width} height={height} rx="16" fill="url(#dots)" />

  <!-- Layer 1: Bare Metal / GPU -->
  <g transform={`translate(40, ${isHome ? 40 : 56})`}>
    <rect x="0" y="0" width={width - 80} height="48" rx="12" class="fill-slate-100 stroke-slate-200" stroke-width="1.5" />
    <text x="24" y="30" class="fill-slate-700 text-sm font-semibold" style="font-family: Inter, system-ui, sans-serif;">裸金属 / GPU / RDMA / 存储</text>
    {!isHome && (
      <text x={width - 104} y="30" class="fill-slate-400 text-xs" text-anchor="end" style="font-family: Inter, system-ui, sans-serif;">基础设施层</text>
    )}
  </g>

  <!-- Arrow -->
  <g transform={`translate(${width / 2 - 12}, ${isHome ? 96 : 112})`}>
    <path d="M12 0v16M4 10l8 8 8-8" class="stroke-slate-300" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <!-- Layer 2: Cluster Orchestration -->
  <g transform={`translate(40, ${isHome ? 116 : 140})`}>
    <rect x="0" y="0" width={width - 80} height="48" rx="12" class="fill-slate-100 stroke-slate-200" stroke-width="1.5" />
    <text x="24" y="30" class="fill-slate-700 text-sm font-semibold" style="font-family: Inter, system-ui, sans-serif;">集群编排：K8s / Slurm</text>
    {!isHome && (
      <text x={width - 104} y="30" class="fill-slate-400 text-xs" text-anchor="end" style="font-family: Inter, system-ui, sans-serif;">编排层</text>
    )}
  </g>

  <!-- Arrow -->
  <g transform={`translate(${width / 2 - 12}, ${isHome ? 172 : 196})`}>
    <path d="M12 0v16M4 10l8 8 8-8" class="stroke-slate-300" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <!-- Layer 3: Platform Services -->
  <g transform={`translate(40, ${isHome ? 192 : 224})`}>
    <rect x="0" y="0" width={width - 80} height="48" rx="12" class="fill-brand-50 stroke-brand-200" stroke-width="1.5" />
    <text x="24" y="30" class="fill-brand-800 text-sm font-semibold" style="font-family: Inter, system-ui, sans-serif;">平台服务：纳管 / 调度 / 可观测 / 配额</text>
    {!isHome && (
      <text x={width - 104} y="30" class="fill-brand-400 text-xs" text-anchor="end" style="font-family: Inter, system-ui, sans-serif;">平台层</text>
    )}
  </g>

  <!-- Arrow -->
  <g transform={`translate(${width / 2 - 12}, ${isHome ? 248 : 280})`}>
    <path d="M12 0v16M4 10l8 8 8-8" class="stroke-brand-300" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <!-- Layer 4: Inference API / Ultralisk Core -->
  <g transform={`translate(40, ${isHome ? 256 : 304})`}>
    <rect x="0" y="0" width={width - 80} height="40" rx="12" class="fill-brand-600 stroke-brand-700" stroke-width="1.5" />
    <text x="24" y="25" class="fill-white text-sm font-semibold" style="font-family: Inter, system-ui, sans-serif;">推理 API / Ultralisk Core（鉴权 · 限流 · 安全 · 监控 · 日志）</text>
    {!isHome && (
      <text x={width - 104} y="25" class="fill-brand-100 text-xs" text-anchor="end" style="font-family: Inter, system-ui, sans-serif;">接入层 · 已开源</text>
    )}
  </g>
</svg>
