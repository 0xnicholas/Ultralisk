---
export interface Props {
  before: string[];
  after: string[];
  title?: string;
}

const { before, after, title } = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  {title && <h3 class="mb-6 text-center text-lg font-semibold text-slate-900">{title}</h3>}

  <div class="grid gap-6 md:grid-cols-2">
    <div class="rounded-xl bg-slate-50 p-5">
      <p class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-200 text-slate-600" aria-hidden="true">×</span>
        Before
      </p>
      <ul class="space-y-3">
        {before.map((item) => (
          <li class="flex items-start gap-3 text-sm text-slate-700">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-400" aria-hidden="true"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="rounded-xl bg-brand-50 p-5">
      <p class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-brand-700">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-600 text-white" aria-hidden="true">✓</span>
        After
      </p>
      <ul class="space-y-3">
        {after.map((item) => (
          <li class="flex items-start gap-3 text-sm text-slate-800">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500" aria-hidden="true"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
