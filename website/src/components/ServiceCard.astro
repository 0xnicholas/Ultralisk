---
export interface Props {
  title: string;
  description: string;
  items: string[];
}

const { title, description, items } = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
  <h3 class="text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-slate-600">{description}</p>
  <ul class="mt-5 space-y-2">
    {items.map((item) => (
      <li class="flex items-start gap-2 text-sm text-slate-700">
        <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-500" aria-hidden="true"></span>
        {item}
      </li>
    ))}
  </ul>
</div>
