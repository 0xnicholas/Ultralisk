---
const action = 'https://formspree.io/f/PLACEHOLDER';
---

<form
  id="contact-form"
  action={action}
  method="POST"
  class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
  novalidate
>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="contact-name" class="block text-sm font-medium text-slate-700">姓名 <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        id="contact-name"
        type="text"
        name="name"
        required
        autocomplete="name"
        class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
        placeholder="您的姓名"
      />
    </div>

    <div>
      <label for="contact-company" class="block text-sm font-medium text-slate-700">公司 <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        id="contact-company"
        type="text"
        name="company"
        required
        autocomplete="organization"
        class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
        placeholder="公司名称"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="contact-email" class="block text-sm font-medium text-slate-700">邮箱 <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        id="contact-email"
        type="email"
        name="email"
        required
        autocomplete="email"
        class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
        placeholder="name@company.com"
      />
    </div>

    <div>
      <label for="contact-phone" class="block text-sm font-medium text-slate-700">电话 <span class="text-slate-400">（可选）</span></label>
      <input
        id="contact-phone"
        type="tel"
        name="phone"
        autocomplete="tel"
        class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
        placeholder="+86 138 0000 0000"
      />
    </div>
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-medium text-slate-700">需求描述 <span class="text-red-500" aria-hidden="true">*</span></label>
    <textarea
      id="contact-message"
      name="message"
      required
      minlength="10"
      rows="4"
      class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
      placeholder="请描述您的需求，至少 10 个字"
    ></textarea>
    <p class="mt-1 text-xs text-slate-500">最少 10 个字</p>
  </div>

  <!-- Honeypot field -->
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

  <button
    type="submit"
    id="contact-submit"
    class="inline-flex w-full items-center justify-center rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
  >
    <span id="submit-text">提交</span>
    <span id="submit-loader" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/30 border-t-white" aria-hidden="true"></span>
  </button>

  <div id="form-status" class="hidden rounded-lg p-3 text-sm" role="status" aria-live="polite"></div>
</form>

<script>
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitText = document.getElementById('submit-text');
    const submitLoader = document.getElementById('submit-loader');
    const statusEl = document.getElementById('form-status');

    if (!form || !submitBtn || !submitText || !submitLoader || !statusEl) return;

    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      submitText.textContent = loading ? '提交中…' : '提交';
      submitLoader.classList.toggle('hidden', !loading);
    }

    function showStatus(message: string, type: 'success' | 'error') {
      statusEl.textContent = message;
      statusEl.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700', 'bg-red-50', 'text-red-700');
      if (type === 'success') {
        statusEl.classList.add('bg-emerald-50', 'text-emerald-700');
      } else {
        statusEl.classList.add('bg-red-50', 'text-red-700');
      }
    }

    function hideStatus() {
      statusEl.classList.add('hidden');
      statusEl.textContent = '';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      hideStatus();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      setLoading(true);

      try {
        const response = await fetch(form.action, {
          method: form.method,
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          showStatus('提交成功，我们会尽快与您联系。', 'success');
          form.reset();
        } else {
          const data = await response.json().catch(() => null);
          showStatus(data?.error || '提交失败，请稍后重试。', 'error');
        }
      } catch (error) {
        showStatus('网络错误，请检查网络连接后重试。', 'error');
      } finally {
        setLoading(false);
      }
    });
  })();
</script>
