---
export interface Props {
  steps: { title: string; description: string }[];
}

const { steps } = Astro.props;
---

<div class="relative">
  <ol class="relative z-10 grid gap-8 md:grid-cols-4">
    {steps.map((step, index) => (
      <li class="relative flex gap-4 md:block">
        <div class="flex flex-col items-center md:flex-row md:items-start">
          <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border-2 border-brand-600 bg-white text-sm font-bold text-brand-600 md:relative md:z-10">
            {index + 1}
          </span>
          {index < steps.length - 1 && (
            <span class="mt-2 h-full w-0.5 bg-brand-200 md:absolute md:left-5 md:top-10 md:mt-0 md:h-0.5 md:w-[calc(100%-2.5rem)]" aria-hidden="true"></span>
          )}
        </div>
        <div class="md:mt-5">
          <h3 class="text-base font-semibold text-slate-900">{step.title}</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-600">{step.description}</p>
        </div>
      </li>
    ))}
  </ol>
</div>
